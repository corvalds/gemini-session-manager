{
  "manifest_version": 3,
  "name": "Gemini Session Manager",
  "version": "1.0.0",
  "description": "A Chrome extension for managing Gemini sessions",
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["src/storage.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
